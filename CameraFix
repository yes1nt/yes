loadstring(game:HttpGet("https://raw.githubusercontent.com/yes1nt/yes/refs/heads/main/Script%20Tools/Advertisement.lua"))()
pcall(function()
	if not getgenv().CameraSubjectSpoof then
		getgenv().CameraSubjectSpoof = true

		-- Fix Camera
		task.spawn(function()
			local function targetScript()
				local player = game.Players.LocalPlayer
				local char = player.Character
				if not char then return nil end
				local handler = char:FindFirstChild("CharacterHandler")
				if not handler then return nil end
				return handler:FindFirstChild("Client")
			end
			local function currentCamera()
				return workspace.CurrentCamera
			end
			local mt = getrawmetatable(game)
			setreadonly(mt, false)
			local oldNewIndex = mt.__newindex
			mt.__newindex = newcclosure(function(self, key, value)
				if self == currentCamera() and key == "CameraSubject" then
					local caller = getcallingscript()
					if caller == targetScript() then
						return
					end
				end
				return oldNewIndex(self, key, value)
			end)
			setreadonly(mt, true)
		end)

		-- Shiftlock Attribute changer
		task.spawn(function()
			local LocalPlayer = game.Players.LocalPlayer
			local UserInputService = game:GetService("UserInputService")
			local function OnShiftLockChanged(Enabled)
				LocalPlayer:SetAttribute("ShiftLockOn", Enabled)
			end
			local LastState = UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
			OnShiftLockChanged(LastState)
			UserInputService:GetPropertyChangedSignal("MouseBehavior"):Connect(function()
				local State = UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
				if State ~= LastState then
					LastState = State
					OnShiftLockChanged(State)
				end
			end)
		end)

	end
end)

