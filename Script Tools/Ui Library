--// Cleanup
function Window:Unload()
    for _, conn in ipairs(self.Connections or {}) do
        if typeof(conn) == "RBXScriptConnection" then
            conn:Disconnect()
        end
    end
    self.ScreenGui:Destroy()
    for i, w in ipairs(BeautifulUI.Windows) do
        if w == self then
            table.remove(BeautifulUI.Windows, i)
            break
        end
    end
end

--// Mobile Support
if UserInputService.TouchEnabled then
    BeautifulUI.Mobile = true
end

--// Auto-load config
pcall(function()
    BeautifulUI:LoadConfig()
end)

return BeautifulUI
