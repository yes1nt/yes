    window.MinimizeBtn.MouseButton1Click:Connect(function()
        window:Minimize()
    end)

    window.MaximizeBtn.MouseButton1Click:Connect(function()
        window:Maximize()
    end)

    window.SettingsBtn.MouseButton1Click:Connect(function()
        window:ToggleSettings()
    end)

    window.MainFrame.InputBegan:Connect(function()
        window:BringToFront()
    end)

    window:InitSettingsPanel()

    table.insert(self.Windows, window)

    window.MainFrame.Size = UDim2.new(0, window.Size.X.Offset * 0.8, 0, window.Size.Y.Offset * 0.8)
    window.MainFrame.BackgroundTransparency = 1
    window.Shadow.ImageTransparency = 1

    Utility.Tween(window.MainFrame, {
        Size = window.Size,
        BackgroundTransparency = self.Settings.Glassmorphism and 0.2 or 0
    }, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    Utility.Tween(window.Shadow, {ImageTransparency = 0.6}, 0.5)

    return window
end

function Window:BringToFront()
    BeautifulUI.ZIndexCounter = BeautifulUI.ZIndexCounter + 1
    self.MainFrame.ZIndex = BeautifulUI.ZIndexCounter
    self.Shadow.ZIndex = BeautifulUI.ZIndexCounter - 1
end

function Window:Close()
    Utility.Tween(self.MainFrame, {Size = UDim2.new(0, self.MainFrame.AbsoluteSize.X * 0.8, 0, self.MainFrame.AbsoluteSize.Y * 0.8), BackgroundTransparency = 1}, 0.3)
    Utility.Tween(self.Shadow, {ImageTransparency = 1}, 0.3, nil, nil, function()
        self.ScreenGui:Destroy()
        for i, w in ipairs(BeautifulUI.Windows) do
            if w == self then
                table.remove(BeautifulUI.Windows, i)
                break
            end
        end
    end)
end

function Window:Minimize()
    if self.Maximized then
        self:Maximize()
        return
    end
    self.Minimized = not self.Minimized
    if self.Minimized then
        self.ContentContainer.Visible = false
        self.TabContainer.Visible = false
        self.OriginalSize = self.MainFrame.Size
        Utility.Tween(self.MainFrame, {Size = UDim2.new(0, 200, 0, 36)}, 0.3)
        self.MinimizeBtn.Text = "+"
    else
        self.ContentContainer.Visible = true
        self.TabContainer.Visible = true
        Utility.Tween(self.MainFrame, {Size = self.OriginalSize or self.Size}, 0.3)
        self.MinimizeBtn.Text = "-"
    end
end

function Window:Maximize()
    self.Maximized = not self.Maximized
    if self.Maximized then
        self.OriginalPos = self.MainFrame.Position
        self.OriginalSize = self.MainFrame.Size
        Utility.Tween(self.MainFrame, {
            Position = UDim2.new(0, 10, 0, 10),
            Size = UDim2.new(1, -20, 1, -20)
        }, 0.3)
        self.MaximizeBtn.Text = "❐"
    else
        Utility.Tween(self.MainFrame, {
            Position = self.OriginalPos or self.Position,
            Size = self.OriginalSize or self.Size
        }, 0.3)
        self.MaximizeBtn.Text = "□"
    end
end

function Window:FilterElements(searchText)
    searchText = string.lower(searchText)
    for _, tab in ipairs(self.Tabs) do
        local tabVisible = false
        for _, section in ipairs(tab.Sections) do
            local sectionVisible = false
            for _, element in ipairs(section.Elements) do
                local name = string.lower(element.Name or "")
                local visible = searchText == "" or string.find(name, searchText, 1, true)
                element.Instance.Visible = visible
                if visible then sectionVisible = true end
            end
            section.Frame.Visible = sectionVisible or searchText == ""
            if sectionVisible then tabVisible = true end
        end
    end
end

