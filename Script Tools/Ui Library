function Window:ToggleSettings()
    local visible = not self.SettingsPanel.Visible
    self.SettingsPanel.Visible = visible
    self.ContentContainer.Visible = not visible
    self.TabContainer.Visible = not visible

    if visible then
        self:PopulateSettings()
    end
end

function Window:PopulateSettings()
    for _, child in ipairs(self.SettingsPanel:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") or child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    local theme = BeautifulUI:GetTheme()

    local title = Utility.Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
        Text = "UI Settings",
        TextColor3 = theme.Text,
        Font = BeautifulUI.Settings.Font,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.SettingsPanel
    })

    self:CreateSettingsDropdown(self.SettingsPanel, "Theme", {"Dark", "Light"}, BeautifulUI.Settings.Theme, function(val)
        BeautifulUI:SetTheme(val)
    end)

    self:CreateSettingsColorPicker(self.SettingsPanel, "Accent Color", BeautifulUI.Settings.Accent, function(color)
        BeautifulUI.Settings.Accent = color
        BeautifulUI:ApplyTheme()
        BeautifulUI:SaveConfig()
    end)

    self:CreateSettingsToggle(self.SettingsPanel, "Glassmorphism", BeautifulUI.Settings.Glassmorphism, function(val)
        BeautifulUI.Settings.Glassmorphism = val
        BeautifulUI:SaveConfig()
    end)

    self:CreateSettingsSlider(self.SettingsPanel, "Corner Radius", 0, 16, BeautifulUI.Settings.CornerRadius, function(val)
        BeautifulUI.Settings.CornerRadius = val
    end)

    self:CreateSettingsSlider(self.SettingsPanel, "Animation Speed", 0, 1, BeautifulUI.Settings.AnimationSpeed, function(val)
        BeautifulUI.Settings.AnimationSpeed = val
    end)

    self:CreateSettingsSlider(self.SettingsPanel, "UI Scale", 0.5, 1.5, BeautifulUI.Settings.Scale, function(val)
        BeautifulUI.Settings.Scale = val
        for _, w in ipairs(BeautifulUI.Windows) do
