function Section:CreateSlider(config)
    config = config or {}
    local name = config.Name or "Slider"
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or min
    local increment = config.Increment or 1
    local suffix = config.Suffix or ""
    local callback = config.Callback or function() end
    local flag = config.Flag or name

    local theme = BeautifulUI:GetTheme()
    local frame = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundTransparency = 1,
        LayoutOrder = #self.Elements + 1,
        Parent = self.ElementContainer
    })

    local label = Utility.Create("TextLabel", {
        Size = UDim2.new(0.6, 0, 0, 18),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = theme.Text,
        Font = BeautifulUI.Settings.Font,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame
    })
    BeautifulUI:RegisterThemeObject(label, "Text")

    local valueLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(0, 50, 0, 18),
        Position = UDim2.new(1, -50, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(default) .. suffix,
        TextColor3 = theme.TextSecondary,
        Font = BeautifulUI.Settings.Font,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = frame
    })
    BeautifulUI:RegisterThemeObject(valueLabel, "TextSecondary")

    local track = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 4),
        Position = UDim2.new(0, 0, 0, 30),
        BackgroundColor3 = theme.BackgroundTertiary,
        BorderSizePixel = 0,
        Parent = frame
    })
    local tCorner = Utility.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = track})

    local fill = Utility.Create("Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel = 0,
        Parent = track
    })
    local fCorner = Utility.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fill})
    BeautifulUI:RegisterThemeObject(fill, "Accent")

    local value = default
    local function setValue(val)
        val = math.clamp(val, min, max)
        val = math.floor(val / increment + 0.5) * increment
        value = val
        local percent = (val - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        valueLabel.Text = tostring(val) .. suffix
        callback(val)
        BeautifulUI.Flags[flag] = {Type = "number", Value = value, SetValue = setValue}
        BeautifulUI:SaveConfig()
    end

    local dragging = false
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            local percent = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            setValue(min + (max - min) * percent)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local percent = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            setValue(min + (max - min) * percent)
        end
    end)

    BeautifulUI:RegisterFlag(flag, "number", default, setValue)

    local element = {Name = name, Type = "Slider", Instance = frame, SetValue = setValue, GetValue = function() return value end}
    table.insert(self.Elements, element)
    return element
end

