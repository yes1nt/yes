--// Environment Detection
local function GetHUI()
    if gethui then
        return gethui()
    end
    return CoreGui
end

local function ProtectInstance(instance)
    instance.Parent = GetHUI()
end

local function IsFileSystem()
    return writefile and readfile and isfile and isfolder and makefolder
end

--// Utilities
local Utility = {}

function Utility.Create(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        if prop ~= "Parent" then
            instance[prop] = value
        end
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utility.Tween(instance, properties, duration, easingStyle, easingDirection, callback)
    local tween = TweenService:Create(instance, TweenInfo.new(
        duration or BeautifulUI.Settings.AnimationSpeed,
        easingStyle or BeautifulUI.Settings.EasingStyle,
        easingDirection or BeautifulUI.Settings.EasingDirection
    ), properties)
    if callback then
        tween.Completed:Once(callback)
    end
    tween:Play()
    return tween
end

function Utility.FadeIn(instance, duration)
    instance.BackgroundTransparency = 1
    Utility.Tween(instance, {BackgroundTransparency = instance:GetAttribute("OriginalTransparency") or 0}, duration)
end

function Utility.FadeOut(instance, duration, callback)
    Utility.Tween(instance, {BackgroundTransparency = 1}, duration, nil, nil, callback)
end

function Utility.MakeDraggable(frame, handle, onDragStart, onDragEnd)
    local dragging = false
    local dragInput, dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            if onDragStart then onDragStart() end

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if onDragEnd then onDragEnd() end
                end
            end)
        end
    end)

    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    local connection = UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    return connection
end

function Utility.MakeResizable(frame, minSize, onResize)
    minSize = minSize or Vector2.new(200, 150)
    local handle = Utility.Create("Frame", {
        Name = "ResizeHandle",
        Size = UDim2.new(0, 15, 0, 15),
        Position = UDim2.new(1, -15, 1, -15),
        BackgroundTransparency = 1,
        ZIndex = frame.ZIndex + 10,
        Parent = frame
    })

    local icon = Utility.Create("ImageLabel", {
        Size = UDim2.new(0, 10, 0, 10),
        Position = UDim2.new(1, -12, 1, -12),
        BackgroundTransparency = 1,
        Image = "rbxassetid://8551326092",
        ImageColor3 = Color3.fromRGB(150, 150, 150),
        ZIndex = frame.ZIndex + 11,
        Parent = frame
    })

    local dragging = false
    local startSize, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startSize = frame.AbsoluteSize
            startPos = input.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - startPos
            local newWidth = math.max(minSize.X, startSize.X + delta.X)
            local newHeight = math.max(minSize.Y, startSize.Y + delta.Y)
            frame.Size = UDim2.new(0, newWidth, 0, newHeight)
            if onResize then onResize(newWidth, newHeight) end
        end
    end)
end

function Utility.RGBtoHSV(color)
    local r, g, b = color.R, color.G, color.B
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, v
    v = max
    local d = max - min
    s = max == 0 and 0 or d / max
    if max == min then
        h = 0
    elseif max == r then
        h = (g - b) / d + (g < b and 6 or 0)
    elseif max == g then
        h = (b - r) / d + 2
    else
        h = (r - g) / d + 4
    end
    h = h / 6
    return h, s, v
end

function Utility.HSVtoRGB(h, s, v)
    local r, g, b
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then r, g, b = v, t, p
    elseif i == 1 then r, g, b = q, v, p
    elseif i == 2 then r, g, b = p, v, t
    elseif i == 3 then r, g, b = p, q, v
    elseif i == 4 then r, g, b = t, p, v
    elseif i == 5 then r, g, b = v, p, q
    end
    return Color3.new(r, g, b)
end

function Utility.CopyTable(tbl)
    local copy = {}
    for k, v in pairs(tbl) do
        if type(v) == "table" then
            copy[k] = Utility.CopyTable(v)
        else
            copy[k] = v
        end
    end
    return copy
end

--// Theme System
function BeautifulUI:GetTheme()
    return self.CustomThemes[self.Settings.Theme] or self.Themes[self.Settings.Theme] or self.Themes.Dark
end

function BeautifulUI:SetTheme(themeName)
    if self.Themes[themeName] or self.CustomThemes[themeName] then
        self.Settings.Theme = themeName
        self:ApplyTheme()
        self:SaveConfig()
    end
end

function BeautifulUI:SetCustomTheme(name, colors)
    self.CustomThemes[name] = colors
    self:SetTheme(name)
end

function BeautifulUI:ApplyTheme()
    local theme = self:GetTheme()
    for _, obj in ipairs(self.Registry.ThemeObjects or {}) do
        if obj.Instance and obj.Instance.Parent then
            if obj.Type == "Background" then
                obj.Instance.BackgroundColor3 = theme.Background
            elseif obj.Type == "BackgroundSecondary" then
                obj.Instance.BackgroundColor3 = theme.BackgroundSecondary
            elseif obj.Type == "Text" then
                obj.Instance.TextColor3 = theme.Text
            elseif obj.Type == "TextSecondary" then
                obj.Instance.TextColor3 = theme.TextSecondary
            elseif obj.Type == "Border" then
                obj.Instance.Color = theme.Border
            elseif obj.Type == "Accent" then
                obj.Instance.BackgroundColor3 = theme.Accent
            end
        end
    end
end

function BeautifulUI:RegisterThemeObject(instance, type)
    table.insert(self.Registry.ThemeObjects, {Instance = instance, Type = type})
end

--// Config System
function BeautifulUI:SaveConfig(configName)
    if not self.Settings.UseConfig then return end
    configName = configName or self.Settings.ConfigName
    local data = {}

    for flag, info in pairs(self.Flags) do
        if info.Type == "Color3" then
            data[flag] = {R = info.Value.R, G = info.Value.G, B = info.Value.B}
        else
            data[flag] = info.Value
        end
    end

    data.__Settings = self.Settings
    local encoded = HttpService:JSONEncode(data)

    if IsFileSystem() then
        writefile(configName, encoded)
    else
        self.Config[configName] = encoded
    end
end

function BeautifulUI:LoadConfig(configName)
    if not self.Settings.UseConfig then return end
    configName = configName or self.Settings.ConfigName
    local encoded

    if IsFileSystem() and isfile(configName) then
        encoded = readfile(configName)
    else
        encoded = self.Config[configName]
    end

    if encoded then
        local success, data = pcall(function() return HttpService:JSONDecode(encoded) end)
        if success and data then
            if data.__Settings then
                for k, v in pairs(data.__Settings) do
                    if k ~= "ConfigName" then
                        self.Settings[k] = v
                    end
                end
            end

            for flag, value in pairs(data) do
                if flag ~= "__Settings" and self.Flags[flag] then
                    local info = self.Flags[flag]
                    if info.Type == "Color3" and typeof(value) == "table" then
                        value = Color3.new(value.R, value.G, value.B)
                    end
                    if info.SetValue then
                        info.SetValue(value)
                    end
                end
            end
        end
    end
end

function BeautifulUI:RegisterFlag(flag, type, defaultValue, setValueFunc)
    self.Flags[flag] = {
        Type = type,
        Value = defaultValue,
        SetValue = setValueFunc
    }
end

