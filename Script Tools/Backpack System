--// ============================================================
--// CHARACTER RESET
--// ============================================================
table.insert(EventConnections, Player.CharacterAdded:Connect(function(Character)
    API.BackpackData.EquippedTools = {}
    API.BackpackData.CurrentPage = 1
    for tool, conn in pairs(ToolConnections) do
        conn:Disconnect()
    end
    ToolConnections = {}
    API.BackpackData.AllItems = {}
    API.Refresh()
    BackpackConnection:Disconnect()
    CharacterConnection:Disconnect()
    BackpackConnection = Player.Backpack.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            task.wait()
            AddItem(child)
        end
    end)
    CharacterConnection = Character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            task.wait()
            AddItem(child)
        end
    end)
    table.insert(EventConnections, BackpackConnection)
    table.insert(EventConnections, CharacterConnection)
    for _, tool in ipairs(Player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            AddItem(tool)
        end
    end
    for _, tool in ipairs(Character:GetChildren()) do
        if tool:IsA("Tool") then
            AddItem(tool)
        end
    end
end))
