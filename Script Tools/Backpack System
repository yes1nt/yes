--// UI
--// ============================================================
local function UpdateNavButtons()
    local totalPages = GetTotalPages()
    if API.BackpackData.CurrentPage <= 1 then
        PrevButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        PrevButton.TextColor3 = Color3.fromRGB(120, 120, 120)
        PrevButton.Active = false
    else
        PrevButton.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        PrevButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        PrevButton.Active = true
    end
    if API.BackpackData.CurrentPage >= totalPages then
        NextButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        NextButton.TextColor3 = Color3.fromRGB(120, 120, 120)
        NextButton.Active = false
    else
        NextButton.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        NextButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        NextButton.Active = true
    end
    PageLabel.Text = API.BackpackData.CurrentPage .. " / " .. totalPages
end
function API.Refresh()
    local itemCount = #API.BackpackData.AllItems
    if itemCount == 0 then
        MainFrame.Visible = false
        return
    else
        MainFrame.Visible = true
    end
    for i = 1, CONFIG.SlotsPerPage do
        local slot = HotbarSlots[i]
        local icon = slot:FindFirstChild("Icon")
        local count = slot:FindFirstChild("Count")
        local equipped = slot:FindFirstChild("Equipped")
        icon.Image = ""
        count.Text = ""
        count.Visible = false
        equipped.BackgroundTransparency = 1
        slot.Visible = false
    end
    local pageItems = GetItemsOnPage(API.BackpackData.CurrentPage)
    for i, item in ipairs(pageItems) do
        local slot = HotbarSlots[i]
        if not slot then continue end
        slot.Visible = true
        local icon = slot:FindFirstChild("Icon")
        local count = slot:FindFirstChild("Count")
        local equipped = slot:FindFirstChild("Equipped")
        icon.Image = item.Icon or ""
        if item.Count and item.Count > 1 then
            count.Text = tostring(item.Count)
            count.Visible = true
        end
        if item.Tool and API.BackpackData.EquippedTools[item.Tool] then
            equipped.BackgroundTransparency = 0.3
        end
    end
    UpdateNavButtons()
end
--// ============================================================
--// INVENTORY
--// ============================================================
local function RemoveItem(toolInstance)
    local foundIndex = nil
    for i, item in ipairs(API.BackpackData.AllItems) do
        if item.Tool == toolInstance then
            foundIndex = i
            break
        end
    end
    if not foundIndex then return false end
    table.remove(API.BackpackData.AllItems, foundIndex)
    API.BackpackData.EquippedTools[toolInstance] = nil
    if ToolConnections[toolInstance] then
        ToolConnections[toolInstance]:Disconnect()
        ToolConnections[toolInstance] = nil
    end
    local totalPages = GetTotalPages()
    if API.BackpackData.CurrentPage > totalPages and totalPages > 0 then
        API.BackpackData.CurrentPage = totalPages
    end
    if API.BackpackData.CurrentPage < 1 then
        API.BackpackData.CurrentPage = 1
    end
    API.Refresh()
    return true
end
local function AddItem(toolInstance)
    for _, item in ipairs(API.BackpackData.AllItems) do
        if item.Tool == toolInstance then
            return true
        end
    end
    table.insert(API.BackpackData.AllItems, {
        Name = toolInstance.Name,
        Icon = toolInstance.TextureId,
        Tool = toolInstance,
        Count = 1
    })
    ToolConnections[toolInstance] = toolInstance.AncestryChanged:Connect(function(_, newParent)
        if newParent == nil then
            RemoveItem(toolInstance)
        elseif newParent ~= Character() and newParent ~= Player.Backpack then
            RemoveItem(toolInstance)
        elseif newParent == Character() then
            API.BackpackData.EquippedTools[toolInstance] = true
            API.Refresh()
        elseif newParent == Player.Backpack then
            API.BackpackData.EquippedTools[toolInstance] = nil
            API.Refresh()
        end
    end)
    API.Refresh()
    return true
end
--// ============================================================
--// EQUIP SYSTEM
--// ============================================================

function API.EquipSlot(slotIndex)
    local globalIndex = API.GetGlobalIndex(slotIndex)
    local item = API.BackpackData.AllItems[globalIndex]
    if not item or not item.Tool then return end
    for _, other in ipairs(API.BackpackData.AllItems) do
        if other.Tool ~= item.Tool and other.Tool.Parent == Character() then
            other.Tool.Parent = Player.Backpack
            API.BackpackData.EquippedTools[other.Tool] = nil
        end
    end
    item.Tool.Parent = Character()
    if item.Tool.Parent == Character() then
        API.BackpackData.EquippedTools[item.Tool] = true
    end
    API.Refresh()
end

function API.UnequipSlot(slotIndex)
    local globalIndex = API.GetGlobalIndex(slotIndex)
    local item = API.BackpackData.AllItems[globalIndex]
    if not item or not item.Tool then return end
    if item.Tool.Parent == Character() then
        item.Tool.Parent = Player.Backpack
    end
    API.BackpackData.EquippedTools[item.Tool] = nil
    API.Refresh()
end
local function UseSlot(slotIndex)
    local globalIndex = API.GetGlobalIndex(slotIndex)
    local item = API.BackpackData.AllItems[globalIndex]
    if not item or not item.Tool then return end
    if IsToolEquipped(item.Tool) and item.Tool.Parent == Character() then
        API.UnequipSlot(slotIndex)
        return
    end
    API.EquipSlot(slotIndex)
end
