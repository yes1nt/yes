task.spawn(function()
    repeat task.wait() until not API
    pcall(function()
        ScreenGui:Destroy()
    end)
end)
table.insert(EventConnections, ScreenGui.AncestryChanged:Connect(function()
    if not ScreenGui:IsDescendantOf(game) then
        -- Disconnect all event connections
        for _, conn in ipairs(EventConnections) do
            pcall(function() conn:Disconnect() end)
        end
        EventConnections = {}
        -- Disconnect all tool connections
        for tool, conn in pairs(ToolConnections) do
            pcall(function() conn:Disconnect() end)
        end
        ToolConnections = {}
        -- Clear data
        API.BackpackData.AllItems = {}
        API.BackpackData.EquippedTools = {}
        API.BackpackData.CurrentPage = 1
        -- Deletes API
        table.clear(API)
        API = nil
        -- Re-enable default backpack
        pcall(function()
            game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true)
        end)
    end
end))
