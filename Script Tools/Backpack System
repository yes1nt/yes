--// ============================================================
--// HELPERS
--// ============================================================
local function GetTotalPages()
    local count = #API.BackpackData.AllItems
    if count == 0 then return 1 end
    return math.ceil(count / CONFIG.SlotsPerPage)
end
local function GetItemsOnPage(pageNum)
    local startIdx = (pageNum - 1) * CONFIG.SlotsPerPage + 1
    local endIdx = math.min(pageNum * CONFIG.SlotsPerPage, #API.BackpackData.AllItems)
    local items = {}
    for i = startIdx, endIdx do
        table.insert(items, API.BackpackData.AllItems[i])
    end
    return items
end
function API.GetGlobalIndex(slotIndex)
    return (API.BackpackData.CurrentPage - 1) * CONFIG.SlotsPerPage + slotIndex
end
local function IsToolEquipped(tool)
    return tool ~= nil and API.BackpackData.EquippedTools[tool] == true
end
