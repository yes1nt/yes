--// TOP LEFT TOGGLE
--// ============================================================
pcall(function()
    game:GetService("CoreGui").TopBarApp.TopBarApp.UnibarLeftFrame.UnibarMenu["2"]["2"].Size = UDim2.new(1.5, 0, 1, 0)
    local Parent = game:GetService("CoreGui").TopBarApp.TopBarApp.UnibarLeftFrame.UnibarMenu["2"]["3"]
    local Leftmost, Rightmost, Closest
    local ClosestDistance = math.huge
    for _, v in ipairs(Parent:GetChildren()) do
        if v:IsA("GuiObject") then
            if not Leftmost or v.AbsolutePosition.X < Leftmost.AbsolutePosition.X then
                Leftmost = v
            end
            if not Rightmost or v.AbsolutePosition.X > Rightmost.AbsolutePosition.X then
                Rightmost = v
            end
        end
    end
    for _, v in ipairs(Parent:GetChildren()) do
        if v:IsA("GuiObject") and v ~= Leftmost then
            local Distance = v.AbsolutePosition.X - Leftmost.AbsolutePosition.X
            if Distance > 0 and Distance < ClosestDistance then
                ClosestDistance = Distance
                Closest = v
            end
        end
    end
    local Clone
    if Leftmost and Rightmost and Closest then
        local Delta = Closest.Position - Leftmost.Position
        Clone = Leftmost:Clone()
        Clone.Name = "backpack_toggle"
        Clone.Parent = Parent
        Clone.Position = Rightmost.Position + Delta
        for _, Child in ipairs(Clone:GetChildren()) do
            Child:Destroy()
        end
        local Label = Instance.new("TextLabel")
        Label.Name = "Backpack"
        Label.BackgroundTransparency = 1
        Label.AnchorPoint = Vector2.new(0.5, 0.5)
        Label.Position = UDim2.fromScale(0.5, 0.5)
        Label.Size = UDim2.fromScale(0.7, 0.7)
        Label.Text = "🎒"
        Label.TextScaled = true
        Label.Font = Enum.Font.SourceSans
        Label.Parent = Clone
        local ClickOverlay = Instance.new("TextButton")
        ClickOverlay.Name = "ClickOverlay"
        ClickOverlay.Size = UDim2.new(1, 0, 1, 0)
        ClickOverlay.BackgroundTransparency = 1
        ClickOverlay.Text = ""
        ClickOverlay.Parent = Clone
    end
    task.spawn(function()
        repeat task.wait() until not API
        Clone:Destroy()
        game:GetService("CoreGui").TopBarApp.TopBarApp.UnibarLeftFrame.UnibarMenu["2"]["2"].Size = UDim2.new(1, 0, 1, 0)
    end)
end)
